<style>
  :root {
    --black: #080a0d;
    --deep: #0d1117;
    --panel: #111820;
    --border: #1e2d3d;
    --accent: #3b82f6;
    --accent-glow: rgba(59,130,246,0.12);
    --accent2: #ff4757;
    --gold: #f0a500;
    --text: #c8d6e5;
    --muted: #5a7a94;
    --white: #f0f4f8;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body { background:var(--black); color:var(--text); font-family:'DM Sans',sans-serif; overflow-x:hidden; min-height:100vh; display:flex; flex-direction:column; }
  body::before {
    content:''; position:fixed; inset:0; pointer-events:none; z-index:999;
    background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(59,130,246,0.012) 2px,rgba(59,130,246,0.012) 4px);
  }

  /* NAV */
  nav { position:fixed; top:0; left:0; right:0; z-index:100; display:flex; align-items:center; justify-content:space-between; padding:16px 48px; background:rgba(8,10,13,0.92); backdrop-filter:blur(12px); border-bottom:1px solid var(--border); }
  .logo { font-family:'Bebas Neue',sans-serif; font-size:22px; letter-spacing:4px; color:var(--accent); text-decoration:none; }
  .nav-cta { font-family:'DM Mono',monospace; font-size:11px; letter-spacing:2px; text-transform:uppercase; background:transparent; border:1px solid var(--accent); color:var(--accent); padding:8px 20px; cursor:pointer; transition:all .2s; text-decoration:none; }
  .nav-cta:hover { background:var(--accent); color:var(--white); }

  /* MAIN LAYOUT */
  main { flex:1; padding:120px 48px 80px; max-width:1100px; margin:0 auto; width:100%; }
  
  .section-label { font-family:'DM Mono',monospace; font-size:10px; letter-spacing:4px; text-transform:uppercase; color:var(--accent); margin-bottom:16px; }
  .section-title { font-family:'Bebas Neue',sans-serif; font-size:clamp(40px,5vw,60px); line-height:1; color:var(--white); margin-bottom:24px; }
  .section-intro { font-size:15px; line-height:1.8; color:var(--text); max-width:700px; margin-bottom:64px; }
  .section-intro strong { color:var(--white); font-weight:500; }

  /* TEAM GRID */
  .team-grid { display:grid; grid-template-columns:repeat(2, 1fr); gap:48px; }

  /* TEAM CARD */
  .team-card { background:var(--panel); border:1px solid var(--border); padding:40px 32px; text-align:center; position:relative; transition:border-color .3s, box-shadow .3s; }
  .team-card:hover { border-color:rgba(59,130,246,0.4); box-shadow:0 8px 32px rgba(59,130,246,0.08); }
  
  .team-photo { width:140px; height:140px; border-radius:50%; margin:0 auto 24px; overflow:hidden; border:2px solid var(--border); position:relative; background:var(--deep); }
  .team-photo img { width:100%; height:100%; object-fit:cover; filter:grayscale(20%); transition:filter .3s; }
  .team-card:hover .team-photo img { filter:grayscale(0%); }
  
  .team-name { font-family:'Bebas Neue',sans-serif; font-size:28px; letter-spacing:2px; color:var(--white); margin-bottom:4px; }
  .team-role { font-family:'DM Mono',monospace; font-size:11px; letter-spacing:2px; text-transform:uppercase; color:var(--accent); margin-bottom:20px; }
  
  .team-bio { font-size:13px; line-height:1.7; color:var(--text); margin-bottom:24px; }
  .team-bio strong { color:var(--white); font-weight:500; }

  /* TAGS */
  .team-tags { display:flex; flex-wrap:wrap; justify-content:center; gap:8px; margin-bottom:24px; }
  .tag { font-family:'DM Mono',monospace; font-size:10px; letter-spacing:1px; text-transform:uppercase; padding:6px 12px; background:rgba(59,130,246,0.08); border:1px solid rgba(59,130,246,0.2); color:var(--muted); }

  /* SOCIAL LINK */
  .team-social { display:inline-flex; align-items:center; gap:8px; font-family:'DM Mono',monospace; font-size:11px; letter-spacing:1px; color:var(--accent); text-decoration:none; border-bottom:1px dashed var(--accent); padding-bottom:2px; transition:color .2s, border-color .2s; }
  .team-social:hover { color:var(--white); border-color:var(--white); }
  .team-social svg { width:14px; height:14px; }

  /* BOTTOM CTA */
  .bottom-section { margin-top:80px; padding:48px; background:transparent; border:1px solid rgba(59,130,246,0.2); text-align:center; }
  .bottom-section h3 { font-family:'Bebas Neue',sans-serif; font-size:32px; letter-spacing:2px; color:var(--white); margin-bottom:16px; }
  .bottom-section p { font-size:14px; line-height:1.7; color:var(--text); max-width:500px; margin:0 auto 24px; }
  .bottom-cta { display:inline-block; font-family:'DM Mono',monospace; font-size:11px; letter-spacing:2px; text-transform:uppercase; background:var(--accent); border:none; color:var(--white); padding:14px 32px; cursor:pointer; transition:all .2s; text-decoration:none; }
  .bottom-cta:hover { background:#2563eb; }

  /* FOOTER */
  footer { background:var(--panel); border-top:1px solid var(--border); padding:32px 48px; display:flex; align-items:center; justify-content:space-between; margin-top:auto; }
  .footer-logo { font-family:'Bebas Neue',sans-serif; font-size:24px; letter-spacing:6px; color:var(--accent); }
  .footer-text { font-family:'DM Mono',monospace; font-size:10px; letter-spacing:2px; color:var(--muted); }

  @media(max-width:800px){
    nav { padding:16px 24px; }
    main { padding:100px 24px 60px; }
    .team-grid { grid-template-columns:1fr; gap:32px; }
    .team-card { padding:32px 24px; }
    footer { flex-direction:column; gap:16px; text-align:center; }
  }
</style>
</head>
